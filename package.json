{
  "name": "japan-weather",
  "description": "Lightweight japan weather for SD2 small TV",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/node.ts",
    "build": "tsc",
    "deploy:wrangler": "wrangler deploy",
    "deploy:vercel": "vercel --prod",
    "dev:worker": "wrangler dev",
    "dev:vercel": "vercel dev"
  },
  "keywords": [
    "japan",
    "weather",
    "earthquake",
    "tsunami",
    "hono"
