    "@hono/swagger-ui": "^0.6.1",
    "@hono/zod-openapi": "^1.4.0",
    "cheerio": "^1.2.0",
    "hono": "^4.7.4",
    "hono-rate-limiter": "^0.5.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260625.1",
    "@types/bun": "^1.3.14",
    "@types/node": "^22.20.0",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3",
    "vercel": "^54.17.0",
    "wrangler": "^4.21.0"
  }
